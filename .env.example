# 複製成 .env 後填入。

# OpenAI API key —— 一律需要(embedding 固定用 OpenAI text-embedding-3-large;
# 生成走 OpenAI 模型時也用這把 key)。
OPENAI_API_KEY=sk-...

# (選填)生成 LLM 後端 / 模型;runner 的 --gen-backend / --gen-model 會再覆寫這兩個。
# 不設時用 config.yaml 的 generation 區塊。
# GEN_BACKEND=openai
# GEN_MODEL=gpt-5.4-mini

# COST_DIR 由 runner 自動設定(指到 <output-dir>/costs),這裡不用填。
